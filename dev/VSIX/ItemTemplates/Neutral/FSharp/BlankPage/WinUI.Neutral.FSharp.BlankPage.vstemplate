<?xml version="1.0" encoding="utf-8"?>
<VSTemplate Version="3.0.0" Type="Item" xmlns="http://schemas.microsoft.com/developer/vstemplate/2005" xmlns:sdk="http://schemas.microsoft.com/developer/vstemplate-sdkextension/2010">
  <TemplateData>
    <DefaultName>BlankPage.xaml</DefaultName>
    <Name ID="1001" Package="FIXME-PACKAGEGUID">Windows App SDK F# Blank Page</Name>
    <Description ID="1003" Package="FIXME-PACKAGEGUID">A blank page for F# WinUI applications</Description>
    <Icon>WinUI.Neutral.FSharp.BlankPage.ico</Icon>
    <ProjectType>FSharp</ProjectType>
    <TemplateID>WinUI.Neutral.FSharp.BlankPage</TemplateID>
    <TemplateGroupID>WinRT-Managed-UAP</TemplateGroupID>
    <AppliesTo>FSharp + WindowsAppSDK</AppliesTo>
    <NumberOfParentCategoriesToRollUp>2</NumberOfParentCategoriesToRollUp>
    <ShowByDefault>false</ShowByDefault>
    <TargetPlatformName>Windows</TargetPlatformName>
    <LanguageTag>F#</LanguageTag>
    <LanguageTag>XAML</LanguageTag>
    <PlatformTag>windows</PlatformTag>
    <ProjectTypeTag>WinUI</ProjectTypeTag>
  </TemplateData>
  <TemplateContent>
    <ProjectItem OpenInEditor="true" ReplaceParameters="true" ItemType="Page" CustomTool="MSBuild:Compile" TargetFileName="$fileinputname$.xaml">BlankPage.xaml</ProjectItem>
    <ProjectItem ReplaceParameters="true" TargetFileName="$fileinputname$.xaml.fs">BlankPage.xaml.fs</ProjectItem>
  </TemplateContent>
</VSTemplate>